# Core backend settings
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<database>?retryWrites=true&w=majority
JWT_SECRET=replace-with-strong-secret

# Optional MongoDB connection tuning
MONGO_MAX_POOL_SIZE=30
MONGO_MIN_POOL_SIZE=5
MONGO_MAX_IDLE_TIME_MS=60000
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000
MONGO_SOCKET_TIMEOUT_MS=45000
MONGO_CONNECT_TIMEOUT_MS=10000

# Optional behavior flags
SKIP_SEED_ON_START=true
FORCE_SEED_ON_START=false

# Optional recommendation service keys
WEAVIATE_HOST=
WEAVIATE_API_KEY=
GOOGLE_AI_API_KEY=
